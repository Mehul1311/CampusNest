# Copy this to your EC2 server as .env and fill in the values.
# Never commit .env to git.

# Server
PORT=5000
NODE_ENV=production

# AWS RDS (PostgreSQL)
PGHOST=your-rds-endpoint.region.rds.amazonaws.com
PGPORT=5432
PGDATABASE=campus_olx
PGUSER=postgres
PGPASSWORD=your_rds_master_password
PGSSLMODE=require

# JWT - use: openssl rand -base64 48
JWT_SECRET=your_long_random_jwt_secret
JWT_EXPIRES_IN=7d

# Razorpay
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
PLATFORM_FEE_PERCENT=25

# Your deployed frontend URL (no trailing slash)
FRONTEND_URL=https://your-frontend-domain.com

# Firebase: use base64 to avoid .env escaping issues (recommended).
# 1) Download firebase-service-account.json from Firebase Console.
# 2) PowerShell from project-backend: [Convert]::ToBase64String([System.Text.Encoding]::UTF8.GetBytes([System.IO.File]::ReadAllText("firebase-service-account.json")))
# 3) Paste the one-line output below. Remove FIREBASE_SERVICE_ACCOUNT_JSON if you use this.
FIREBASE_SERVICE_ACCOUNT_BASE64=paste_base64_output_here